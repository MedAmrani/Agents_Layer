import com.networknt.schema.*
import com.fasterxml.jackson.databind.ObjectMapper
import javax.xml.validation.SchemaFactory
import javax.xml.transform.stream.StreamSource
import javax.xml.XMLConstants
import org.apache.nifi.processor.io.InputStreamCallback
import java.nio.charset.StandardCharsets
import java.io.StringReader

def flowFile = session.get()
if (!flowFile) return

def rawContentType = flowFile.getAttribute('mime.type') ?: flowFile.getAttribute('content.type')
def raw = rawContentType?.toLowerCase()

def contentType = raw?.contains('json') ? 'json' :
                  raw?.contains('xml')  ? 'xml'  :
                  null

def schemaStr = flowFile.getAttribute('validation.schema')

if (!schemaStr?.trim()) {
    flowFile = session.putAttribute(flowFile, 'validation.status', 'invalid')
    flowFile = session.putAttribute(flowFile, 'validation.errors',
        'No schema found in FlowFile attribute [validation.schema]')
    session.transfer(flowFile, REL_FAILURE)
    return
}

if (!contentType) {
    flowFile = session.putAttribute(flowFile, 'validation.status', 'invalid')
    flowFile = session.putAttribute(flowFile, 'validation.errors',
        "Unknown or missing mime/content type [${rawContentType}]. Expected JSON or XML.")
    session.transfer(flowFile, REL_FAILURE)
    return
}

def content = ''
session.read(flowFile, { inputStream ->
    content = inputStream.getText(StandardCharsets.UTF_8.name())
} as InputStreamCallback)

if (!content?.trim()) {
    flowFile = session.putAttribute(flowFile, 'validation.status', 'invalid')
    flowFile = session.putAttribute(flowFile, 'validation.errors', 'FlowFile content is empty')
    session.transfer(flowFile, REL_FAILURE)
    return
}

try {
    if (contentType == 'json') {
        def mapper = new ObjectMapper()
        def factory = JsonSchemaFactory.getInstance(SpecVersion.VersionFlag.V7)

        def schemaNode = mapper.readTree(schemaStr)
        def schema = factory.getSchema(schemaNode)
        def jsonNode = mapper.readTree(content)
        def errors = schema.validate(jsonNode)

        if (errors.isEmpty()) {
            flowFile = session.putAttribute(flowFile, 'validation.status', 'valid')
            flowFile = session.putAttribute(flowFile, 'validation.type', 'json')
            session.transfer(flowFile, REL_SUCCESS)
        } else {
            def errorList = errors.collect { it.message ?: it.toString() }
            def errorMsg = errorList.take(10).join('; ')
            if (errorList.size() > 10) {
                errorMsg += "; ... ${errorList.size() - 10} more errors"
            }

            flowFile = session.putAttribute(flowFile, 'validation.status', 'invalid')
            flowFile = session.putAttribute(flowFile, 'validation.type', 'json')
            flowFile = session.putAttribute(flowFile, 'validation.errors', errorMsg)
            session.transfer(flowFile, REL_FAILURE)
        }

    } else if (contentType == 'xml') {
        def schemaFactory = SchemaFactory.newInstance(XMLConstants.W3C_XML_SCHEMA_NS_URI)
        try {
            schemaFactory.setProperty(XMLConstants.ACCESS_EXTERNAL_DTD, "")
            schemaFactory.setProperty(XMLConstants.ACCESS_EXTERNAL_SCHEMA, "")
        } catch (Exception ignored) {
            // Some environments may not support these properties
        }

        def xsdSchema = schemaFactory.newSchema(new StreamSource(new StringReader(schemaStr)))
        def validator = xsdSchema.newValidator()

        try {
            validator.validate(new StreamSource(new StringReader(content)))
            flowFile = session.putAttribute(flowFile, 'validation.status', 'valid')
            flowFile = session.putAttribute(flowFile, 'validation.type', 'xml')
            session.transfer(flowFile, REL_SUCCESS)
        } catch (Exception validationEx) {
            flowFile = session.putAttribute(flowFile, 'validation.status', 'invalid')
            flowFile = session.putAttribute(flowFile, 'validation.type', 'xml')
            flowFile = session.putAttribute(flowFile, 'validation.errors',
                validationEx.message ?: validationEx.toString())
            session.transfer(flowFile, REL_FAILURE)
        }
    }
} catch (Exception e) {
    flowFile = session.putAttribute(flowFile, 'validation.status', 'invalid')
    flowFile = session.putAttribute(flowFile, 'validation.errors',
        "Script error: ${e.message ?: e.toString()}")
    session.transfer(flowFile, REL_FAILURE)
}
