                def refName = requestBodyDef.'$ref'.tokenize('/').last()
                requestBodyDef = spec.components?.requestBodies?.get(refName) as Map
            }

            // resolve schema — inline or $ref to components/schemas
            def schema = requestBodyDef?.content?.get('application/json')?.schema as Map
            if (schema?.'$ref') {
                def refName = schema.'$ref'.tokenize('/').last()
                schema = spec.components?.schemas?.get(refName) as Map
            }

            // Swagger 2.x body parameter schema
            if (!schema) {
                def bodyParam = parameters.find { (it as Map).in == 'body' }
                schema = (bodyParam as Map)?.schema as Map
            }
