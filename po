import com.networknt.schema.JsonSchemaFactory
import com.networknt.schema.SpecVersion

def flowFile = session.get()
if (!flowFile) return

flowFile = session.putAttribute(flowFile, "test.class", JsonSchemaFactory.class.getName())
flowFile = session.putAttribute(flowFile, "test.versionflag", SpecVersion.VersionFlag.V7.toString())
session.transfer(flowFile, REL_SUCCESS)
